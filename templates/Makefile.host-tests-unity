# Makefile — host tests (Unity framework)
# Copy this to your embedded C project root.
# Adapt INCS and CORE_SRCS to your project structure.

CC = gcc
CFLAGS = -Wall -Wextra -Werror -g -O0 -std=c11
INCS = -Isrc -Ilib -Ilib/unity

# Unity framework source
UNITY_SRC = lib/unity/unity.c

# Production source files needed by tests (exclude platform/hardware)
CORE_SRCS = $(wildcard src/core/*.c) $(wildcard src/storage/*.c)

# Test files (one per module)
TEST_SRCS = $(wildcard test/host/*.c)
TEST_BINS = $(patsubst test/host/%.c,build/%,$(TEST_SRCS))

.PHONY: all clean

all: $(TEST_BINS)
	@set -e; \
	passed=0; failed=0; \
	for t in $(TEST_BINS); do \
		echo "--- $$t ---"; \
		if "$$t"; then \
			passed=$$((passed+1)); \
		else \
			failed=$$((failed+1)); \
		fi; \
	done; \
	echo "== $$passed passed, $$failed failed =="; \
	[ $$failed -eq 0 ]

# Each test binary links unity + core sources
build/%: test/host/%.c $(UNITY_SRC) $(CORE_SRCS) | builddir
	$(CC) $(CFLAGS) $(INCS) -o $@ $< $(UNITY_SRC) $(CORE_SRCS) -lm

builddir:
	mkdir -p build

clean:
	rm -rf build
