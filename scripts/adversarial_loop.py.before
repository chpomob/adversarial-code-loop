#!/usr/bin/env python3
"""Adversarial Code Loop — Sequential DEV -> REVIEW -> FIX -> VERIFY -> ARBITER."""
import sys, json, os, re, signal, subprocess, tempfile, argparse, shlex
from pathlib import Path
from datetime import datetime

WRAPPER = os.environ.get("ACL_WRAPPER", "python3 /home/chpo/.hermes/skills/autonomous-ai-agents/hermes-agent/scripts/claude-tmux.py")

# ----- Personas (full Multi-Persona texts, mirrored from SKILL.md) -----
BUILDER_PERSONA = """Tu es un·e Développeur·se Senior Production.
Mission : écris du code prêt pour la production. Tu es méthodique : types stricts,
gestion d'erreur exhaustive, performances, lisibilité, tests inclus. Tu ne coupes pas
les coins ronds. Si une spec est ambiguë, documente tes hypothèses dans des commentaires.
Si l'écriture de fichiers est refusée, produis le code source COMPLET inline dans des
blocs de code markdown — n'attends pas la permission.
Style : clean code, défensif, documenté."""

CRITIC_PERSONA = """Tu es un·e Pair Reviewer Adversaire.
Tu as UN job : trouver ce qui ne va PAS. Tu es impitoyable mais constructif. Cherche les
bugs, failles de sécurité, race conditions, problèmes de perf, edge cases non gérés, api
design douteux. Tu travailles en fresh context — tu n'as PAS écrit ce code.
Structure chaque finding avec `severity`, `file`, `line`, `description`.
Output : JSON {"findings": [...], "verdict": "APPROVE|REQUEST_CHANGES|REJECT", "summary": "..."}.
Style : adversarial, précis, sourcé."""

FIXER_PERSONA = """Tu es un·e Correcteur·rice Méthodique.
Tu as reçu une review. Tu adresses CHAQUE finding un par un. Si le reviewer a raison →
corrige. Si tu penses qu'il a tort → explique POURQUOI avec preuves (pas de défense
dogmatique). Produis un diff précis pour chaque correction.
IMPORTANT : ton output doit inclure un champ `updated_code` contenant le code source
COMPLET corrigé (pas seulement les diffs). Sans ce champ, code_text reste inchangé et les
cycles suivants travaillent sur l'ancien code. updated_code est une chaîne vide si rien
n'a été modifié. target_file est le chemin relatif du fichier principal modifié.
Format de sortie (JSON) :
{
  "responses": [...],
  "target_file": "<chemin relatif du fichier principal>",
  "updated_code": "<code source COMPLET corrigé, chaîne vide si inchangé>",
  "all_fixed": true,
  "summary": "3/4 findings fixed, 1 disputed"
}
Style : réactif, précis, humble."""

VERIFIER_PERSONA = """Tu es un·e Gatekeeper.
Tu as déjà reviewé ce code. Vérifie que TOUS tes points ont été adressés. Pour chaque
point : RESOLVED si corrigé, NOT_ADDRESSED si toujours présent. Si tous résolus → APPROVE.
Si un seul point non adressé → REJECT avec la liste restante.
Output : JSON {"verdict": "APPROVE|REJECT", "findings": [...], "summary": "..."}.
Style : méticuleux, checklist, binaire."""

JUDGE_PERSONA = """Tu es un·e Arbitre Technique.
Le développeur et le reviewer sont en désaccord après plusieurs rounds. Analyse
objectivement les deux positions. Tranche en faveur de la position la plus justifiée
techniquement. Produis une décision claire avec les changements à appliquer.
Quand le verdict est CODE_NEEDS_FIXES, inclus TOUJOURS le patch minimal concret (code
diff) pour les findings non résolus, pas seulement un avis général.
Termine TOUJOURS ta réponse par une ligne exactement de la forme :
VERDICT: APPROVED | CODE_NEEDS_FIXES | REJECT
Style : objectif, décisif, synthétique, précis."""


def write_persona_file(name, content):
    path = Path(tempfile.gettempdir()) / f"acl-persona-{name}.txt"
    path.write_text(content)
    return str(path)


def _detect_provider(cmd):
    """Return 'claude-tmux', 'claude', 'codex', or 'other' from a command string."""
    if 'claude-tmux' in cmd or 'claude_tmux' in cmd:
        return 'claude-tmux'
    if 'codex' in cmd:
        return 'codex'
    if 'claude' in cmd:
        return 'claude'
    return 'other'


def _strip_json_wrapper(text):
    """Strip markdown code fences / prose preamble and return the largest valid
    JSON object found in the text (ported from adversarial_review.py)."""
    if not text:
        return text
    cleaned = re.sub(r'```(?:json)?\s*\n?', '', text)
    cleaned = re.sub(r'\n?```', '', cleaned)
    candidates = []
    pos = 0
    while pos < len(cleaned):
        brace = cleaned.find('{', pos)
        if brace == -1:
            break
        try:
            obj, end = json.JSONDecoder().raw_decode(cleaned[brace:])
            candidates.append((brace + end, json.dumps(obj)))
            pos = brace + end
        except json.JSONDecodeError:
            pos = brace + 1
    if not candidates:
        return text
    candidates.sort(key=lambda c: len(c[1]), reverse=True)
    return candidates[0][1]


def _fail_phase(label, code, stderr):
    """Terminate the run when a CLI phase fails — never feed downstream phases.

    Ported from adversarial_review.py (finding CV1)."""
    print(f"X Phase '{label}' failed (exit code {code})")
    if stderr:
        snippet = stderr[:500]
        suffix = "…" if len(stderr) > 500 else ""
        print(f"   stderr: {snippet}{suffix}")
    sys.exit(1)


def run_cli(cmd, stdin_text=None, timeout=600, cwd=None, persona_file=None):
    """Run a CLI command (shell=False), optionally injecting a persona.

    Persona injection (polyglot): Claude/claude-tmux receive
    `--append-system-prompt-file <path>`; Codex and other providers get the
    persona text prefixed to stdin (no system-prompt flag available).

    Uses temp files (not pipes) for stdout/stderr and `start_new_session=True`
    so a hung sandbox grandchild cannot deadlock us on a full pipe buffer; on
    timeout the whole process group is killed.
    """
    if isinstance(cmd, str):
        try:
            argv = shlex.split(cmd)
        except ValueError as e:
            return "", f"Invalid command syntax: {e}", -1
    elif isinstance(cmd, (list, tuple)):
        argv = list(cmd)
    else:
        return "", f"Unsupported command type: {type(cmd).__name__}", -1
    if not argv:
        return "", "Empty command", -1

    if persona_file:
        provider = _detect_provider(" ".join(argv))
        # Only the native `claude` CLI supports --append-system-prompt-file.
        # claude-tmux.py (strict argparse), codex and others have no such flag,
        # so inject the persona by prefixing it to stdin instead.
        if provider == "claude":
            argv += ["--append-system-prompt-file", persona_file]
        else:
            try:
                persona_text = Path(persona_file).read_text()
            except OSError:
                persona_text = ""
            if persona_text:
                stdin_text = f"{persona_text}\n\n{stdin_text or ''}"

    out_f = tempfile.TemporaryFile(mode="w+", encoding="utf-8")
    err_f = tempfile.TemporaryFile(mode="w+", encoding="utf-8")
    try:
        try:
            proc = subprocess.Popen(
                argv,
                stdin=subprocess.PIPE if stdin_text is not None else subprocess.DEVNULL,
                stdout=out_f, stderr=err_f, text=True, cwd=cwd,
                start_new_session=True,
            )
        except FileNotFoundError as e:
            return "", f"Command not found: {e}", 127
        except OSError as e:
            return "", f"OS error: {e}", -1
        try:
            proc.communicate(input=stdin_text, timeout=timeout)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
            except (ProcessLookupError, OSError):
                pass
            proc.wait()
            out_f.seek(0)
            return out_f.read().strip(), f"TIMEOUT after {timeout}s", 124
        out_f.seek(0)
        err_f.seek(0)
        return out_f.read().strip(), err_f.read().strip(), proc.returncode
    finally:
        out_f.close()
        err_f.close()


def save_artifact(out_dir, name, content):
    path = Path(out_dir) / name
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    return path


def snapshot_workdir(workdir):
    """Record files already dirty at pipeline start, so the FIXER fallback only
    attributes NEW disk changes (since this snapshot) to the fixer. Returns a set
    of relative paths, or None when workdir is not a git repo."""
    if not (workdir and os.path.isdir(os.path.join(workdir, ".git"))):
        return None
    try:
        proc = subprocess.run(
            ["git", "status", "--porcelain"],
            capture_output=True, text=True, timeout=10, cwd=workdir,
        )
        return {line[3:].strip() for line in proc.stdout.splitlines() if line.strip()}
    except Exception:
        return None


def step_builder(spec_text, dev_cmd, persona_file, out_dir, timeout, workdir=None):
    print(f"\n{'='*60}\n  BUILD  (DEV)\n{'='*60}")
    prompt = f"Implemente la specification:\n\n{spec_text}"
    stdout, stderr, code = run_cli(dev_cmd, stdin_text=prompt, timeout=timeout,
                                   cwd=workdir, persona_file=persona_file)
    save_artifact(out_dir, "01_code.md", stdout)
    if stderr:
        save_artifact(out_dir, "01_code.err", stderr)
    if code != 0:
        _fail_phase("BUILD", code, stderr)
    print(f"  OK Code — {len(stdout)} chars")
    return stdout


def step_critic(code_text, review_cmd, persona_file, out_dir, timeout, workdir=None):
    print(f"\n{'='*60}\n  CRITIQUE  (REVIEW)\n{'='*60}")
    prompt = f"Review ce code:\n\n{code_text}"
    stdout, stderr, code = run_cli(review_cmd, stdin_text=prompt, timeout=timeout,
                                   cwd=workdir, persona_file=persona_file)
    save_artifact(out_dir, "02_review.json", stdout)
    if stderr:
        save_artifact(out_dir, "02_review.err", stderr)
    if code != 0:
        _fail_phase("CRITIQUE", code, stderr)
    try:
        review = json.loads(_strip_json_wrapper(stdout))
        verdict = review.get("verdict", "UNKNOWN")
        n = len(review.get("findings", []))
        print(f"  OK {n} findings — Verdict: {verdict}")
        return stdout, verdict
    except (json.JSONDecodeError, AttributeError):
        print(f"  OK Review ({len(stdout)} chars)")
        return stdout, "UNKNOWN"


def step_fixer(code_text, review_json, dev_cmd, persona_file, out_dir, loop_n, timeout,
               workdir=None, baseline=None):
    print(f"\n{'='*60}\n  FIX  (loop #{loop_n})\n{'='*60}")
    prompt = f"Code original:\n{code_text}\n\nFindings:\n{review_json}"
    stdout, stderr, code = run_cli(dev_cmd, stdin_text=prompt, timeout=timeout,
                                   cwd=workdir, persona_file=persona_file)
    save_artifact(out_dir, f"loop_{loop_n}_03_fix.md", stdout)
    if stderr:
        save_artifact(out_dir, f"loop_{loop_n}_03_fix.err", stderr)
    if code != 0:
        _fail_phase(f"FIX #{loop_n}", code, stderr)
    try:
        fix = json.loads(_strip_json_wrapper(stdout))
        all_fixed = fix.get("all_fixed", False)
        updated_code = fix.get("updated_code", "")
        target_file = fix.get("target_file", "")
        # Don't trust all_fixed if no code was actually returned.
        if all_fixed and not (updated_code or "").strip():
            all_fixed = False
        print(f"  OK all_fixed={all_fixed} updated_code={len(updated_code)}B target={target_file}")
        return stdout, all_fixed, updated_code, target_file
    except (json.JSONDecodeError, AttributeError):
        # Fallback: Codex sandbox modes write directly to the filesystem and
        # return non-JSON stdout. Detect changes since the pipeline-start
        # snapshot (not against an arbitrary baseline that may include
        # pre-existing dirt) and surface them for the VERIFIER.
        print(f"  Fix stdout non-JSON ({len(stdout)} chars) — checking disk changes...")
        all_fixed = False
        updated_code = ""
        target_file = ""
        if workdir and os.path.isdir(os.path.join(workdir, ".git")):
            try:
                status = subprocess.run(
                    ["git", "status", "--porcelain"],
                    capture_output=True, text=True, timeout=10, cwd=workdir,
                )
                current = {line[3:].strip() for line in status.stdout.splitlines() if line.strip()}
                changed = sorted(current - (baseline or set()))
                if changed:
                    # First file changed by THIS fixer, any extension.
                    target_file = changed[0]
                    full_path = os.path.join(workdir, target_file)
                    if os.path.isfile(full_path):
                        try:
                            with open(full_path) as fh:
                                updated_code = fh.read()
                        except OSError:
                            updated_code = ""
                    # Only claim "all_fixed" if we captured real file content.
                    all_fixed = bool(updated_code.strip())
                    print(f"  Detected {len(changed)} new file(s). target={target_file} code={len(updated_code)}B")
                    diff_text = subprocess.run(
                        ["git", "diff"],
                        capture_output=True, text=True, timeout=10, cwd=workdir,
                    ).stdout
                    save_artifact(out_dir, f"loop_{loop_n}_03_fix.diff", diff_text[:5000])
                    if all_fixed:
                        fixed_list = "\n".join(f"  - `{f}`" for f in changed[:20])
                        stdout = json.dumps({
                            "all_fixed": True,
                            "target_file": target_file,
                            "updated_code": updated_code,
                            "summary": f"Fixed {len(changed)} file(s) via sandbox write:\n{fixed_list}\n\nDiff:\n```diff\n{diff_text[:3000]}\n```"
                        }, indent=2)
            except Exception as e:
                print(f"  git diff fallback error: {e}")
        return stdout, all_fixed, updated_code, target_file


def step_verifier(review_original, fix_response, review_cmd, persona_file, out_dir, loop_n,
                  timeout, workdir=None):
    print(f"\n{'='*60}\n  VERIFY  (loop #{loop_n})\n{'='*60}")
    prompt = f"Review originale:\n{review_original}\n\nReponse du dev:\n{fix_response}"
    stdout, stderr, code = run_cli(review_cmd, stdin_text=prompt, timeout=timeout,
                                   cwd=workdir, persona_file=persona_file)
    save_artifact(out_dir, f"loop_{loop_n}_04_verdict.json", stdout)
    if stderr:
        save_artifact(out_dir, f"loop_{loop_n}_04_verdict.err", stderr)
    if code != 0:
        _fail_phase(f"VERIFY #{loop_n}", code, stderr)
    try:
        v = json.loads(_strip_json_wrapper(stdout))
        verdict = v.get("verdict", "UNKNOWN")
        print(f"  OK Verdict: {verdict}")
        return stdout, verdict
    except (json.JSONDecodeError, AttributeError):
        print(f"  OK ({len(stdout)} chars)")
        return stdout, "UNKNOWN"


def parse_arbiter_verdict(text):
    """Extract the JUDGE's actual verdict from its output.

    Looks for an explicit `VERDICT: <x>` line first, then falls back to keyword
    scanning. Returns one of APPROVED / CODE_NEEDS_FIXES / REJECT / ARBITRATED."""
    if not text:
        return "ARBITRATED"
    m = re.search(r'VERDICT\s*[:=]\s*([A-Z_]+)', text, re.IGNORECASE)
    token = m.group(1).upper() if m else ""
    upper = text.upper()
    if token in ("APPROVED", "APPROVE") or "CODE_APPROVED" in upper:
        return "APPROVED"
    if token == "CODE_NEEDS_FIXES" or "CODE_NEEDS_FIXES" in upper:
        return "CODE_NEEDS_FIXES"
    if token in ("REJECT", "REJECTED") or "REJECT" in upper:
        return "REJECT"
    return "ARBITRATED"


def step_arbiter(history, arbiter_cmd, persona_file, out_dir, timeout, workdir=None):
    print(f"\n{'='*60}\n  ARBITRAGE (JUDGE)\n{'='*60}")
    prompt = f"Dossier:\n\n{history}"
    stdout, stderr, code = run_cli(arbiter_cmd, stdin_text=prompt, timeout=timeout,
                                   cwd=workdir, persona_file=persona_file)
    save_artifact(out_dir, "05_arbitrage.md", stdout)
    if stderr:
        save_artifact(out_dir, "05_arbitrage.err", stderr)
    if code != 0:
        _fail_phase("ARBITRAGE", code, stderr)
    verdict = parse_arbiter_verdict(stdout)
    print(f"  OK Arbiter verdict: {verdict}")
    return stdout, verdict


def resolve_target_path(workdir, target_file):
    target = Path(target_file)
    if target.is_absolute():
        raise ValueError("target_file must be relative")
    if ".." in target.parts:
        raise ValueError("target_file must not contain '..'")
    resolved = (Path(workdir).resolve() / target).resolve()
    if not resolved.is_relative_to(Path(workdir).resolve()):
        raise ValueError("target_file resolves outside workdir")
    return resolved


def write_final_report(out_dir, spec_text, code_text, reviews, verdicts, arbiter_result):
    lines = ["# Adversarial Code Loop — Rapport Final", f"Date: {datetime.now().isoformat()}", "",
             "## Resume", f"- **Verdict final**: {verdicts[-1] if verdicts else 'N/A'}",
             f"- **Cycles**: {len(reviews)}", f"- **Arbitrage**: {'Oui' if arbiter_result else 'Non'}", "",
             "## Specification", f"```\n{spec_text}\n```", "", "## Code Final", f"{code_text}", ""]
    path = save_artifact(out_dir, "final.md", "\n".join(lines))
    return path


# Arbiter verdict -> process exit code (distinct, machine-readable).
ARBITER_EXIT_CODES = {
    "APPROVED": 0,
    "CODE_NEEDS_FIXES": 42,
    "REJECT": 1,
    "ARBITRATED": 42,
}


def main():
    p = argparse.ArgumentParser(description="Adversarial Code Loop")
    p.add_argument("--spec", required=True)
    p.add_argument("--workdir", default=os.getcwd())
    p.add_argument("--max-loops", type=int, default=3)
    p.add_argument("--dev-cmd", default=f"{WRAPPER} --model opus --max-turns 20 --yolo")
    p.add_argument("--review-cmd", default="codex exec --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox")
    p.add_argument("--arbiter-cmd", default="")
    p.add_argument("--no-arbiter", action="store_true")
    p.add_argument("--timeout", type=int, default=600)
    p.add_argument("--out", default=".adversarial-loop")
    args = p.parse_args()

    if not os.path.isfile(args.spec):
        print(f"X Spec not found: {args.spec}")
        sys.exit(1)
    spec_text = Path(args.spec).read_text()
    workdir = args.workdir or os.getcwd()

    out_dir = Path(workdir) / args.out if not os.path.isabs(args.out) else Path(args.out)
    out_dir.mkdir(parents=True, exist_ok=True)
    save_artifact(out_dir, "00_spec.txt", spec_text)

    personas = {k: write_persona_file(k, v) for k, v in [
        ("builder", BUILDER_PERSONA), ("critic", CRITIC_PERSONA),
        ("fixer", FIXER_PERSONA), ("verifier", VERIFIER_PERSONA),
        ("judge", JUDGE_PERSONA)]}

    # Snapshot dirty files so the FIXER fallback only counts NEW changes.
    baseline = snapshot_workdir(workdir)

    print(f"\n{'#'*60}\n  ADVERSARIAL CODE LOOP\n  Spec: {args.spec}\n  Max loops: {args.max_loops}\n  DEV: {args.dev_cmd[:60]}\n  REVIEW: {args.review_cmd[:60]}\n{'#'*60}")

    reviews, verdicts = [], []

    code_text = step_builder(spec_text, args.dev_cmd, personas["builder"], out_dir, args.timeout, workdir=workdir)
    reviews.append(("CODE (BUILDER)", code_text))

    review_text, verdict = step_critic(code_text, args.review_cmd, personas["critic"], out_dir, args.timeout, workdir=workdir)
    reviews.append(("CRITIQUE (CRITIC)", review_text))
    verdicts.append(verdict)
    if verdict == "APPROVE":
        print("\nAPPROVED")
        write_final_report(out_dir, spec_text, code_text, reviews, verdicts, None)
        sys.exit(0)

    for n in range(1, args.max_loops + 1):
        fix_text, all_fixed, updated_code, target_file = step_fixer(
            code_text, review_text, args.dev_cmd, personas["fixer"], out_dir, n, args.timeout,
            workdir=workdir, baseline=baseline)
        reviews.append((f"FIX #{n}", fix_text))
        if all_fixed and updated_code.strip() and target_file:
            try:
                tp = resolve_target_path(workdir, target_file)
                tp.parent.mkdir(parents=True, exist_ok=True)
                tp.write_text(updated_code)
                print(f"  -> Wrote {len(updated_code)}B to {target_file}")
                code_text = updated_code
            except (ValueError, TypeError) as e:
                print(f"  X target_file error: {e}")
                sys.exit(1)

        verify_text, verdict = step_verifier(review_text, fix_text, args.review_cmd, personas["verifier"], out_dir, n, args.timeout, workdir=workdir)
        reviews.append((f"VERIFY #{n}", verify_text))
        verdicts.append(verdict)
        if verdict == "APPROVE":
            print(f"\nAPPROVED at cycle #{n}")
            write_final_report(out_dir, spec_text, code_text, reviews, verdicts, None)
            sys.exit(0)

    if args.no_arbiter:
        print(f"\nREJECTED after {args.max_loops} cycles")
        write_final_report(out_dir, spec_text, code_text, reviews, verdicts, None)
        sys.exit(1)

    history = "\n\n".join(["## Specification", spec_text, "## Code", code_text] + [f"### {s}\n{c}" for s, c in reviews])
    arbiter_cmd = args.arbiter_cmd or f"{WRAPPER} --model opus --max-turns 10 --yolo"
    arbiter_text, arbiter_verdict = step_arbiter(history, arbiter_cmd, personas["judge"], out_dir, args.timeout, workdir=workdir)
    reviews.append(("ARBITRAGE", arbiter_text))
    verdicts.append(arbiter_verdict)
    print(f"\nARBITRATED: {arbiter_verdict}")
    write_final_report(out_dir, spec_text, code_text, reviews, verdicts, arbiter_text)
    sys.exit(ARBITER_EXIT_CODES.get(arbiter_verdict, 42))


if __name__ == "__main__":
    main()
